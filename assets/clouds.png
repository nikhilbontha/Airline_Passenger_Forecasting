<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1600 900">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#eef8ff"/>
      <stop offset="100%" stop-color="#ffffff"/>
    </linearGradient>

    <filter id="blur" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="12"/>
    </filter>
  </defs>

  <rect width="1600" height="900" fill="url(#bg)"/>

  <g fill="#ffffff" opacity="0.95" filter="url(#blur)">
    <g transform="translate(120 120)">
      <ellipse cx="120" cy="80" rx="95" ry="52"/>
      <ellipse cx="210" cy="65" rx="85" ry="60"/>
      <ellipse cx="300" cy="88" rx="95" ry="55"/>
      <ellipse cx="205" cy="112" rx="175" ry="60"/>
    </g>

    <g transform="translate(760 80) scale(1.15)">
      <ellipse cx="120" cy="80" rx="95" ry="52"/>
      <ellipse cx="210" cy="65" rx="85" ry="60"/>
      <ellipse cx="300" cy="88" rx="95" ry="55"/>
      <ellipse cx="205" cy="112" rx="175" ry="60"/>
    </g>

    <g transform="translate(280 430) scale(1.5)">
      <ellipse cx="120" cy="80" rx="95" ry="52"/>
      <ellipse cx="210" cy="65" rx="85" ry="60"/>
      <ellipse cx="300" cy="88" rx="95" ry="55"/>
      <ellipse cx="205" cy="112" rx="175" ry="60"/>
    </g>

    <g transform="translate(980 520) scale(1.7)">
      <ellipse cx="120" cy="80" rx="95" ry="52"/>
      <ellipse cx="210" cy="65" rx="85" ry="60"/>
      <ellipse cx="300" cy="88" rx="95" ry="55"/>
      <ellipse cx="205" cy="112" rx="175" ry="60"/>
    </g>
  </g>
</svg>
